      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [740, 200]
    },
    {
      "parameters": {
        "jsCode": "// Extract base64 image from Imagen 3 response\nconst predictions = $input.first().json.predictions;\nif (predictions && predictions.length > 0) {\n  const imageBytes = predictions[0].bytesBase64Encoded;\n  return [{\n    json: {\n      image: {\n        path: `data:image/png;base64,${imageBytes}`,\n        filename: `post-${Date.now()}.png`,\n        isDataUri: true,\n        isMock: false\n      }\n    }\n  }];\n}\n\n// Should not reach here, but fallback\nreturn [{\n  json: {\n    image: {\n      path: 'https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=1080&auto=format&fit=crop',\n      filename: 'mock-placeholder.jpg',\n      isDataUri: false,\n      isMock: true\n    }\n  }\n}];"
      },
