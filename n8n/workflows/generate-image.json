              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"instances\": [\n    {\n      \"prompt\": \"Create a high-quality social media graphic. {{ $json.body.styleInstruction || 'Modern, clean, minimalist design with vibrant colors.' }}\\n\\nSubject: {{ $json.body.visualGist }}\\n\\nThe image should be professional, visually striking, and suitable for Facebook and Instagram. No text in the image.\"\n    }\n  ],\n  \"parameters\": {\n    \"sampleCount\": 1\n  }\n}",
        "options": {
          "timeout": 90000
        }
      },
      "id": "a1b2c3d4-0002-4000-8000-000000000002",
      "name": "Imagen 3 — Generate",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [500, 200],
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
