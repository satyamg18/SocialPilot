    },
    {
      "parameters": {
        "amount": 5,
        "unit": "seconds"
      },
      "id": "a1b2c3d4-0004-4000-8000-000000000007",
      "name": "Wait for IG",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [1160, 460]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v19.0/{{ $('Route Platform').first().json.igUserId }}/media_publish",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"creation_id\": \"{{ $('IG — Create Container').first().json.id }}\",\n  \"access_token\": \"{{ $('Route Platform').first().json.instagramToken }}\"\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "a1b2c3d4-0004-4000-8000-000000000008",
      "name": "IG — Publish",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1360, 460],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Merge results from Facebook and Instagram\nconst results = { facebook: null, instagram: null };\nconst errors = [];\n\n// Check Facebook result\ntry {\n  const li = $('Facebook — Post').first()?.json;\n  if (li && !li.error && !li.message) {\n    results.facebook = { success: true, postId: li['x-restli-id'] || null };\n  } else if (li?.error || li?.message) {\n    errors.push('Facebook: ' + JSON.stringify(li.error || li.message));\n  }\n} catch(e) {\n  // Facebook was skipped\n}\n\n// Check Instagram result\ntry {\n  const ig = $('IG — Publish').first()?.json;\n  if (ig && ig.id) {\n    results.instagram = { postId: ig.id, success: true };\n  } else if (ig?.error) {\n    errors.push('Instagram: ' + JSON.stringify(ig.error));\n  }\n} catch(e) {\n  // Instagram was skipped\n}\n\nconst success = !!(results.facebook || results.instagram);\n\nreturn [{\n  json: {\n    success,\n    results,\n    errors: errors.length > 0 ? errors : undefined\n  }\n}];"
      },
      "id": "a1b2c3d4-0004-4000-8000-000000000009",
      "name": "Merge Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}"
      },
