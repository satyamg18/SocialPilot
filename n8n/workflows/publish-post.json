    {
      "parameters": {
        "jsCode": "// Route to the correct platform(s)\nconst body = $input.first().json.body;\nconst platform = body.platform || 'both';\n\nreturn [{\n  json: {\n    ...body,\n    publishFacebook: platform === 'facebook' || platform === 'both',\n    publishInstagram: platform === 'instagram' || platform === 'both'\n  }\n}];"
      },
      "id": "a1b2c3d4-0004-4000-8000-000000000002",
      "name": "Route Platform",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 300]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "id": "should-facebook",
              "leftValue": "={{ $json.publishFacebook }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ]
        }
      },
      "id": "a1b2c3d4-0004-4000-8000-000000000003",
      "name": "Facebook?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [720, 160]
    },
    {
